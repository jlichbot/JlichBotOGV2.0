# ============================================================
# FastLoop Trader — Railway Environment Variables
# These take priority over clawhub.json and config.json
# ============================================================

# ── Required ──────────────────────────────────────────────────
SIMMER_API_KEY=sk_live_your_key_here
WALLET_PRIVATE_KEY=0x_your_polymarket_wallet_private_key

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8425211968:AAFNlontkGZ1uY-piw0D2cEaWFx5RLUeqxc
TELEGRAM_CHAT_ID=@Jlichbot

# ── Trading mode ──────────────────────────────────────────────
LIVE_TRADING=0          # flip to 1 when ready for real trades

# ── Strategy (must match config.json AND clawhub.json) ───────
SIMMER_SPRINT_ASSET=BTC
SIMMER_SPRINT_WINDOW=5m
DAILY_BUDGET_USD=20
SIMMER_FASTLOOP_DAILY_BUDGET_USD=20
SIMMER_FASTLOOP_MAX_POSITION_USD=5
SIMMER_FASTLOOP_ENTRY_THRESHOLD=0.05
SIMMER_FASTLOOP_MOMENTUM_THRESHOLD=0.3
SIMMER_FASTLOOP_LOOKBACK_MINUTES=5
SIMMER_FASTLOOP_VOL_CONFIDENCE_MIN=0.5
SIMMER_FASTLOOP_MIN_TIME_BETWEEN_TRADES_SEC=60

# ── Optional ──────────────────────────────────────────────────
# NOTIFY_SKIPS=1     # Telegram ping on every skip cycle
# SMART_SIZING=1     # Use 5% of portfolio per trade
